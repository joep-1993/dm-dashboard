# =============================================================================
# DM Dashboard - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Dashboard Authentication ---
# Set a password to protect the dashboard. Leave empty to disable auth.
DASHBOARD_PASSWORD=changeme
# Optional: fixed secret for session tokens (auto-generated if omitted).
# Set this if you want sessions to survive server restarts.
#DASHBOARD_SECRET=some-random-secret-string

# --- AI Configuration ---
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# --- Database ---
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/seo_tools

# --- Redshift (optional, for output) ---
USE_REDSHIFT_OUTPUT=false
REDSHIFT_HOST=your-cluster.region.redshift.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=your_database
REDSHIFT_USER=your_username
REDSHIFT_PASSWORD=your_password
REDSHIFT_OUTPUT_SCHEMA=pa
REDSHIFT_OUTPUT_TABLE=content_urls_joep

# --- Google Ads API (optional, for keyword planner & thema ads) ---
# Get credentials from: https://developers.google.com/google-ads/api/docs/oauth/cloud-project
GOOGLE_DEVELOPER_TOKEN=your_developer_token
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_LOGIN_CUSTOMER_ID=your_customer_id

# --- Beslist Content APIs (optional) ---
UNIQUE_TITLES_API_KEY=your_api_key
CONTENT_API_KEY_DEV=your_dev_key
CONTENT_API_KEY_STAGING=your_staging_key
CONTENT_API_KEY_PROD=your_prod_key

# --- Proxy (optional) ---
#HTTP_PROXY=http://proxy-server:port
#HTTPS_PROXY=http://proxy-server:port
